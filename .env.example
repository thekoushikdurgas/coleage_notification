# ─────────────────────────────────────────────────────────────────────────────
# FormsADDA – Environment Variables Template
#
# Copy this file:   cp .env.example .env
# Then edit .env with your real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=a89fa8fdd3f584e080151fcc750e05cb075db3947837d4c4493004c9e0e580ab81ec1ca10d536b91d19ccce5866261f061cf88a5063900c7dcafc0fc65c7a687

# ── PostgreSQL (must match db service in docker-compose.yml) ───────────────────
POSTGRES_DB=formsadda
POSTGRES_USER=formsadda
POSTGRES_PASSWORD=formsadda_secret

# ── Gunicorn tuning ────────────────────────────────────────────────────────────
# Keep workers=1 when using SQLite; increase only with PostgreSQL
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── Optional: Gemini API key for real AI content generation ────────────────────
GEMINI_API_KEY=
